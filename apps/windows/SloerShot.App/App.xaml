<Application
    x:Class="SloerShot.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
<Color x:Key="SystemAccentColor">#FF3D7EFF</Color>
<Color x:Key="SystemAccentColorLight1">#FF5B92FF</Color>
<Color x:Key="SystemAccentColorLight2">#FF79A6FF</Color>
<Color x:Key="SystemAccentColorLight3">#FF98BAFF</Color>
<Color x:Key="SystemAccentColorDark1">#FF2C6BE0</Color>
<Color x:Key="SystemAccentColorDark2">#FF1F57C0</Color>
<Color x:Key="SystemAccentColorDark3">#FF14439F</Color>
            <SolidColorBrush x:Key="AppBgBrush" Color="#16161A" />
            <SolidColorBrush x:Key="PanelBgBrush" Color="#1F1F25" />
            <SolidColorBrush x:Key="StageBgBrush" Color="#101013" />
            <SolidColorBrush x:Key="ToolbarBgBrush" Color="#2A2A31" />
            <SolidColorBrush x:Key="CardBgBrush" Color="#26262C" />
            <SolidColorBrush x:Key="StrokeBrush" Color="#36363F" />
            <SolidColorBrush x:Key="AccentBrush" Color="#3D7EFF" />
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#5B92FF" />
            <SolidColorBrush x:Key="TextBrush" Color="#ECECEF" />
            <SolidColorBrush x:Key="SubtleTextBrush" Color="#9A9AA6" />
            <Style x:Key="ToolButtonStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="34" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Margin" Value="1,0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style x:Key="IconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="34" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="7" />
                <Setter Property="Margin" Value="1,0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
            <Style x:Key="BigActionButtonStyle" TargetType="Button">
                <Setter Property="Padding" Value="16,11" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
