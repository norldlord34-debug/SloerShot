<Window
x:Class="SloerShot.MainWindow"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:ed="using:SloerShot.Editor"
Title="SloerShot">
<Grid x:Name="Root" RequestedTheme="Dark" Background="{StaticResource AppBgBrush}" RowDefinitions="Auto,*,Auto">
<Grid.KeyboardAccelerators>
<KeyboardAccelerator Modifiers="Control" Key="N" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control,Shift" Key="F" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control,Shift" Key="W" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control" Key="C" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control" Key="S" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control" Key="Z" Invoked="OnAccelerator" />
<KeyboardAccelerator Modifiers="Control" Key="Y" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="Delete" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="V" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="R" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="O" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="A" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="L" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="T" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="H" Invoked="OnAccelerator" />
<KeyboardAccelerator Key="X" Invoked="OnAccelerator" />
</Grid.KeyboardAccelerators>
<Border x:Name="TitleBar" Grid.Row="0" Background="#B31F1F25" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,0,1" Padding="14,9">
<Grid ColumnDefinitions="Auto,*,Auto">
<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
<Border Width="26" Height="26" CornerRadius="7" Background="{StaticResource AccentBrush}">
<FontIcon Glyph="&#xE722;" FontSize="13" Foreground="White" />
</Border>
<TextBlock Text="SloerShot" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
<TextBlock x:Name="CoreVersionText" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="2,3,0,0" />
</StackPanel>
<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,140,0">
<Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFolder" ToolTipService.ToolTip="Open captures folder" AutomationProperties.Name="Open captures folder">
<FontIcon Glyph="&#xE838;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnOpenSettings" ToolTipService.ToolTip="Settings" AutomationProperties.Name="Settings">
<FontIcon Glyph="&#xE713;" FontSize="15" />
</Button>
<DropDownButton VerticalAlignment="Center">
<DropDownButton.Content>
<StackPanel Orientation="Horizontal" Spacing="8">
<FontIcon Glyph="&#xE722;" FontSize="14" />
<TextBlock Text="Capture" />
</StackPanel>
</DropDownButton.Content>
<DropDownButton.Flyout>
<MenuFlyout>
<MenuFlyoutItem Text="Capture Area" Tag="area" Click="OnCaptureOption" />
<MenuFlyoutItem Text="Window" Tag="window" Click="OnCaptureOption" />
<MenuFlyoutItem Text="Fullscreen" Tag="full" Click="OnCaptureOption" />
<MenuFlyoutItem Text="Scrolling Capture" Tag="scroll" Click="OnCaptureOption" />
<MenuFlyoutSeparator />
<MenuFlyoutItem x:Name="RecordMenuItem" Text="Start Recording" Click="OnToggleRecording" />
<MenuFlyoutSeparator />
<MenuFlyoutItem Text="Combine Images..." Click="OnCombineImages" />
</MenuFlyout>
</DropDownButton.Flyout>
</DropDownButton>
</StackPanel>
</Grid>
</Border>
<Grid Grid.Row="1" ColumnDefinitions="248,*">
<Border Grid.Column="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,1,0">
<Grid RowDefinitions="Auto,*">
<Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="16,13,16,9">
<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
<TextBlock Text="Captures" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
<Border CornerRadius="9" Background="{StaticResource CardBgBrush}" Padding="7,1" VerticalAlignment="Center">
<TextBlock x:Name="CaptureCountText" Text="0" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" />
</Border>
</StackPanel>
<ToggleButton Grid.Column="1" x:Name="ViewToggle" Width="34" Height="28" Padding="0" CornerRadius="7" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Click="OnToggleView" ToolTipService.ToolTip="Toggle grid / list view" AutomationProperties.Name="Toggle grid / list view">
<FontIcon Glyph="&#xE80A;" FontSize="14" />
</ToggleButton>
</Grid>
<ListView Grid.Row="1" x:Name="CapturesList" SelectionChanged="OnCaptureSelected" Padding="8,0,8,10">
<ListView.ItemTemplate>
<DataTemplate>
<Grid ColumnDefinitions="Auto,*" ColumnSpacing="11" Padding="2,6">
<Grid.ContextFlyout>
<MenuFlyout>
<MenuFlyoutItem Text="Open in Explorer" Click="OnItemReveal" />
<MenuFlyoutItem Text="Copy image" Click="OnItemCopy" />
<MenuFlyoutItem Text="Copy path" Click="OnItemCopyPath" />
<MenuFlyoutItem Text="Delete" Click="OnItemDelete" />
</MenuFlyout>
</Grid.ContextFlyout>
<Border Grid.Column="0" Width="66" Height="42" CornerRadius="6" Background="#0A0A0C" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
<Image Source="{Binding Thumb}" Stretch="UniformToFill" />
</Border>
<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
<TextBlock Text="{Binding Name}" FontSize="12" Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
<TextBlock Text="{Binding Dims}" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" />
</StackPanel>
</Grid>
</DataTemplate>
</ListView.ItemTemplate>
</ListView>
<GridView Grid.Row="1" x:Name="CapturesGrid" SelectionChanged="OnCaptureSelected" Padding="10,0,10,10" Visibility="Collapsed">
<GridView.ItemTemplate>
<DataTemplate>
<StackPanel Width="104" Margin="4" Spacing="4">
<Border Width="104" Height="66" CornerRadius="6" Background="#0A0A0C" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
<Image Source="{Binding Thumb}" Stretch="UniformToFill" />
</Border>
<TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource SubtleTextBrush}" TextTrimming="CharacterEllipsis" />
</StackPanel>
</DataTemplate>
</GridView.ItemTemplate>
</GridView>
</Grid>
</Border>
<Grid Grid.Column="1" Background="{StaticResource StageBgBrush}">
<ScrollViewer x:Name="StageScroller" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Auto" VerticalScrollMode="Auto" ZoomMode="Disabled" Padding="24,74,24,24">
<Grid x:Name="CanvasHost" HorizontalAlignment="Center" VerticalAlignment="Center">
<Border x:Name="CanvasFrame" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="4">
<Grid>
<ed:AnnotationCanvas x:Name="EditorCanvas" Background="White" />
<Canvas x:Name="SelectionLayer" Background="Transparent" IsHitTestVisible="False" PointerPressed="OnSelectionPressed" PointerMoved="OnSelectionMoved" PointerReleased="OnSelectionReleased" />
</Grid>
</Border>
</Grid>
</ScrollViewer>
<Border x:Name="Toolbar" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,14,0,0" Background="{StaticResource ToolbarBgBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="6,5" Visibility="Collapsed">
<StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
<ToggleButton x:Name="ToolSelect" Style="{StaticResource ToolButtonStyle}" Tag="0" Click="OnToolToggle" ToolTipService.ToolTip="Select / move (V)" AutomationProperties.Name="Select / move (V)">
<PathIcon Data="M3,3 L3,15 L6.5,11.8 L9,17 L11,16 L8.5,10.8 L13,10.8 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolRect" Style="{StaticResource ToolButtonStyle}" Tag="2" Click="OnToolToggle" ToolTipService.ToolTip="Rectangle (R)" AutomationProperties.Name="Rectangle (R)">
<PathIcon Data="F0 M2,4 L14,4 L14,13 L2,13 Z M4.5,6 L4.5,11 L11.5,11 L11.5,6 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolEllipse" Style="{StaticResource ToolButtonStyle}" Tag="3" Click="OnToolToggle" ToolTipService.ToolTip="Ellipse (O)" AutomationProperties.Name="Ellipse (O)">
<PathIcon Data="F0 M2,8 A6,6 0 1 0 14,8 A6,6 0 1 0 2,8 Z M5,8 A3,3 0 1 0 11,8 A3,3 0 1 0 5,8 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolArrow" Style="{StaticResource ToolButtonStyle}" Tag="1" Click="OnToolToggle" ToolTipService.ToolTip="Arrow (A)" AutomationProperties.Name="Arrow (A)">
<PathIcon Data="M2,7.2 L11,7.2 L11,5 L15,8 L11,11 L11,8.8 L2,8.8 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolLine" Style="{StaticResource ToolButtonStyle}" Tag="4" Click="OnToolToggle" ToolTipService.ToolTip="Line (L)" AutomationProperties.Name="Line (L)">
<PathIcon Data="M3,12.3 L12.3,3 L13,3.7 L3.7,13 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolText" Style="{StaticResource ToolButtonStyle}" Tag="6" Click="OnToolToggle" ToolTipService.ToolTip="Text (T)" AutomationProperties.Name="Text (T)">
<TextBlock Text="Aa" FontSize="15" FontWeight="SemiBold" />
</ToggleButton>
<ToggleButton x:Name="ToolCounter" Style="{StaticResource ToolButtonStyle}" Tag="7" Click="OnToolToggle" ToolTipService.ToolTip="Numbered step (N)" AutomationProperties.Name="Numbered step (N)">
<Grid Width="18" Height="18">
<Ellipse Stroke="{StaticResource TextBrush}" StrokeThickness="1.5" />
<TextBlock Text="1" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" />
</Grid>
</ToggleButton>
<ToggleButton x:Name="ToolMarker" Style="{StaticResource ToolButtonStyle}" Tag="8" Click="OnToolToggle" ToolTipService.ToolTip="Highlighter (H)" AutomationProperties.Name="Highlighter (H)">
<PathIcon Data="M3,16 L3,13 L11,5 L14,8 L6,16 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolRedact" Style="{StaticResource ToolButtonStyle}" Tag="9" Click="OnToolToggle" ToolTipService.ToolTip="Redact (X)" AutomationProperties.Name="Redact (X)">
<PathIcon Data="M2,6 L14,6 L14,11 L2,11 Z" />
</ToggleButton>
<Rectangle Width="1" Height="22" Fill="{StaticResource StrokeBrush}" Margin="5,0" />
<ToggleButton x:Name="ToolCrop" Style="{StaticResource ToolButtonStyle}" Tag="fx:crop" Click="OnToolToggle" ToolTipService.ToolTip="Crop to a dragged region" AutomationProperties.Name="Crop to a dragged region">
<PathIcon Data="M2.5,2.5 L7.5,2.5 L7.5,3.7 L3.7,3.7 L3.7,7.5 L2.5,7.5 Z M13.5,13.5 L8.5,13.5 L8.5,12.3 L12.3,12.3 L12.3,8.5 L13.5,8.5 Z" />
</ToggleButton>
<ToggleButton x:Name="ToolPick" Style="{StaticResource ToolButtonStyle}" Tag="fx:pick" Click="OnToolToggle" ToolTipService.ToolTip="Color picker (eyedropper)" AutomationProperties.Name="Color picker (eyedropper)">
<FontIcon Glyph="&#xEF3C;" FontSize="15" />
</ToggleButton>
<ToggleButton x:Name="ToolSpotlight" Style="{StaticResource ToolButtonStyle}" Tag="fx:spotlight" Click="OnToolToggle" ToolTipService.ToolTip="Spotlight a dragged region" AutomationProperties.Name="Spotlight a dragged region">
<PathIcon Data="F0 M2,8 A6,6 0 1 0 14,8 A6,6 0 1 0 2,8 Z M5,8 A3,3 0 1 0 11,8 A3,3 0 1 0 5,8 Z M6.8,8 A1.2,1.2 0 1 0 9.2,8 A1.2,1.2 0 1 0 6.8,8 Z" />
</ToggleButton>
<Rectangle Width="1" Height="22" Fill="{StaticResource StrokeBrush}" Margin="5,0" />
<Button Style="{StaticResource IconButtonStyle}" Click="OnUndo" ToolTipService.ToolTip="Undo (Ctrl+Z)" AutomationProperties.Name="Undo (Ctrl+Z)">
<FontIcon Glyph="&#xE7A7;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnRedo" ToolTipService.ToolTip="Redo (Ctrl+Y)" AutomationProperties.Name="Redo (Ctrl+Y)">
<FontIcon Glyph="&#xE7A6;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnSetText" ToolTipService.ToolTip="Set text of selected annotation" AutomationProperties.Name="Set text of selected annotation">
<FontIcon Glyph="&#xE70F;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnDelete" ToolTipService.ToolTip="Delete selected (Del)" AutomationProperties.Name="Delete selected (Del)">
<FontIcon Glyph="&#xE74D;" FontSize="15" />
</Button>
<Rectangle Width="1" Height="22" Fill="{StaticResource StrokeBrush}" Margin="5,0" />
<Button Style="{StaticResource IconButtonStyle}" Width="48" Click="OnOcr" ToolTipService.ToolTip="Copy text (OCR)" AutomationProperties.Name="Copy text (OCR)"><TextBlock Text="OCR" FontSize="12" /></Button>
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="10,0">
<TextBlock Text="Style" Foreground="{StaticResource TextBrush}" />
<DropDownButton.Flyout>
<Flyout>
<StackPanel Spacing="10">
<TextBlock Text="Color" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<StackPanel Orientation="Horizontal" Spacing="6">
<Button Width="24" Height="24" CornerRadius="12" Background="#E53935" BorderThickness="0" Padding="0" Tag="E53935" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#FB8C00" BorderThickness="0" Padding="0" Tag="FB8C00" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#FDD835" BorderThickness="0" Padding="0" Tag="FDD835" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#43A047" BorderThickness="0" Padding="0" Tag="43A047" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#1E88E5" BorderThickness="0" Padding="0" Tag="1E88E5" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#8E24AA" BorderThickness="0" Padding="0" Tag="8E24AA" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#FFFFFF" BorderThickness="0" Padding="0" Tag="FFFFFF" Click="OnPickColor" />
<Button Width="24" Height="24" CornerRadius="12" Background="#111111" BorderThickness="0" Padding="0" Tag="111111" Click="OnPickColor" />
</StackPanel>
<TextBlock Text="Thickness" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<StackPanel Orientation="Horizontal" Spacing="6">
<Button Content="Thin" Tag="2" Click="OnPickStroke" />
<Button Content="Medium" Tag="4" Click="OnPickStroke" />
<Button Content="Thick" Tag="8" Click="OnPickStroke" />
</StackPanel>
<TextBlock Text="Opacity" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<Slider Minimum="0.1" Maximum="1.0" StepFrequency="0.05" Value="1.0" Width="180" ValueChanged="OnOpacityChanged" />
<CheckBox Content="Fill shapes" Click="OnToggleFill" />
<CheckBox Content="Smart highlighter (snap to text)" Click="OnSmartHighlighter" />
<TextBlock Text="Arrow style" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<ComboBox SelectedIndex="0" Width="180" SelectionChanged="OnArrowStyle">
<ComboBoxItem Content="Straight" />
<ComboBoxItem Content="Curved" />
<ComboBoxItem Content="DoubleHeaded" />
<ComboBoxItem Content="Thin" />
</ComboBox>
<TextBlock Text="Text style" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<ComboBox SelectedIndex="0" Width="180" SelectionChanged="OnTextStyle">
<ComboBoxItem Content="Plain" />
<ComboBoxItem Content="Outline" />
<ComboBoxItem Content="Filled" />
<ComboBoxItem Content="Rounded" />
<ComboBoxItem Content="Bubble" />
<ComboBoxItem Content="Highlight" />
<ComboBoxItem Content="Shadow" />
</ComboBox>
</StackPanel>
</Flyout>
</DropDownButton.Flyout>
</DropDownButton>
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="10,0">
<StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE790;" FontSize="13" VerticalAlignment="Center" /><TextBlock Text="Effects" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" /></StackPanel>
<DropDownButton.Flyout>
<MenuFlyout>
<MenuFlyoutItem Text="Effects studio..." Click="OnEffectsStudio" />
<MenuFlyoutSeparator />
<MenuFlyoutItem Text="Grayscale" Tag="grayscale" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Sepia" Tag="sepia" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Invert" Tag="invert" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Blur" Tag="blur" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Vignette" Tag="vignette" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Brighten" Tag="brighten" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Contrast" Tag="contrast" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Rotate 90" Tag="rotate" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Flip horizontal" Tag="flip" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Add border" Tag="border" Click="OnEffectMenu" />
<MenuFlyoutItem Text="White balance" Tag="whitebalance" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Auto color" Tag="autocolor" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Sharpen" Tag="sharpen" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Flatten document" Tag="flatten" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Scan QR / barcode" Tag="scan" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Auto-straighten" Tag="deskew" Click="OnEffectMenu" />
<MenuFlyoutSeparator />
<MenuFlyoutItem Text="Pixelate" Tag="pixelate" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Emboss" Tag="emboss" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Edge detect" Tag="edge" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Posterize" Tag="posterize" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Black and white" Tag="bw" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Solarize" Tag="solarize" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Colorize" Tag="colorize" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Gamma up" Tag="gamma_up" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Gamma down" Tag="gamma_down" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Hue rotate" Tag="hue" Click="OnEffectMenu" />
<MenuFlyoutItem Text="More saturation" Tag="saturate" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Less saturation" Tag="desaturate" Click="OnEffectMenu" />
<MenuFlyoutSeparator />
<MenuFlyoutItem Text="Glow" Tag="glow" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Outline" Tag="outline" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Drop shadow" Tag="shadow" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Reflection" Tag="reflection" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Polaroid frame" Tag="polaroid" Click="OnEffectMenu" />
<MenuFlyoutItem Text="RGB split" Tag="rgb_split" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Selective color" Tag="selective_color" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Slice glitch" Tag="slice" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Torn edges" Tag="torn_edge" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Wave edges" Tag="wave_edge" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Replace white with black" Tag="replace_white" Click="OnEffectMenu" />
<MenuFlyoutItem Text="Watermark image..." Click="OnWatermarkImage" />
</MenuFlyout>
</DropDownButton.Flyout>
</DropDownButton>
<Rectangle Width="1" Height="22" Fill="{StaticResource StrokeBrush}" Margin="5,0" />
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="10,0">
<StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE90F;" FontSize="13" VerticalAlignment="Center" /><TextBlock Text="Tools" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" /></StackPanel>
<DropDownButton.Flyout>
<MenuFlyout>
<MenuFlyoutSubItem Text="Sharing"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE72D;" /></MenuFlyoutSubItem.Icon>
<MenuFlyoutItem Text="Upload text..." Click="OnUploadText" />
<MenuFlyoutItem Text="Generate QR code..." Click="OnQrTool" />
</MenuFlyoutSubItem>
<MenuFlyoutSubItem Text="Image"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xEB9F;" /></MenuFlyoutSubItem.Icon>
<MenuFlyoutItem Text="Split image..." Click="OnSplitImage" />
<MenuFlyoutItem Text="Create thumbnail..." Click="OnThumbnail" />
<MenuFlyoutItem Text="Hash checker..." Click="OnHashCheck" />
<MenuFlyoutItem Text="Index folder..." Click="OnIndexFolder" />
</MenuFlyoutSubItem>
<MenuFlyoutSubItem Text="Screen"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE7B3;" /></MenuFlyoutSubItem.Icon>
<MenuFlyoutItem Text="Screen color picker..." Click="OnColorPicker" />
<MenuFlyoutItem Text="Screen ruler..." Click="OnScreenRuler" />
</MenuFlyoutSubItem>
<MenuFlyoutSubItem Text="Automation"><MenuFlyoutSubItem.Icon><FontIcon Glyph="&#xE90F;" /></MenuFlyoutSubItem.Icon>
<MenuFlyoutItem Text="Workflows and hotkeys..." Click="OnWorkflows" />
<MenuFlyoutItem Text="External actions..." Click="OnActions" />
</MenuFlyoutSubItem>
</MenuFlyout>
</DropDownButton.Flyout>
</DropDownButton>
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="10,0">
<StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xEB9F;" FontSize="13" VerticalAlignment="Center" /><TextBlock Text="Backdrop" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" /></StackPanel>
<DropDownButton.Flyout>
<Flyout>
<StackPanel Spacing="8" Width="260">
<TextBlock Text="Background" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
<ComboBox x:Name="BgTypeCombo" Header="Type" SelectedIndex="0" Width="230" SelectionChanged="OnBgTypeChanged">
<ComboBoxItem Content="Gradient" /><ComboBoxItem Content="Color" /><ComboBoxItem Content="Transparent" />
</ComboBox>
<TextBlock Text="Gradient" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<StackPanel Orientation="Horizontal" Spacing="6">
<Button Width="24" Height="24" CornerRadius="6" Background="#6366F1" BorderThickness="0" Padding="0" Tag="Indigo" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#F97316" BorderThickness="0" Padding="0" Tag="Sunset" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#0EA5E9" BorderThickness="0" Padding="0" Tag="Ocean" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#22C55E" BorderThickness="0" Padding="0" Tag="Forest" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#EC4899" BorderThickness="0" Padding="0" Tag="Candy" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#0F172A" BorderThickness="0" Padding="0" Tag="Midnight" Click="OnBgPreset" />
<Button Width="24" Height="24" CornerRadius="6" Background="#262626" BorderThickness="0" Padding="0" Tag="Graphite" Click="OnBgPreset" />
</StackPanel>
<TextBlock Text="Color" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<StackPanel Orientation="Horizontal" Spacing="6">
<Button Width="24" Height="24" CornerRadius="6" Background="#FFFFFF" BorderThickness="0" Padding="0" Tag="FFFFFF" Click="OnBgColorSwatch" />
<Button Width="24" Height="24" CornerRadius="6" Background="#111111" BorderThickness="0" Padding="0" Tag="111111" Click="OnBgColorSwatch" />
<Button Width="24" Height="24" CornerRadius="6" Background="#1E88E5" BorderThickness="0" Padding="0" Tag="1E88E5" Click="OnBgColorSwatch" />
<Button Width="24" Height="24" CornerRadius="6" Background="#E53935" BorderThickness="0" Padding="0" Tag="E53935" Click="OnBgColorSwatch" />
</StackPanel>
<TextBlock Text="Padding" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<Slider x:Name="BgPadding" Minimum="0" Maximum="200" Value="64" Width="230" />
<TextBlock Text="Corners" FontSize="12" Foreground="{StaticResource SubtleTextBrush}" />
<Slider x:Name="BgCorners" Minimum="0" Maximum="48" Value="16" Width="230" />
<CheckBox x:Name="BgShadow" Content="Shadow" IsChecked="True" />
<ComboBox x:Name="BgRatio" Header="Ratio" SelectedIndex="0" Width="230">
<ComboBoxItem Content="Auto" /><ComboBoxItem Content="1:1" /><ComboBoxItem Content="4:3" /><ComboBoxItem Content="3:2" /><ComboBoxItem Content="16:9" /><ComboBoxItem Content="9:16" /><ComboBoxItem Content="3:4" />
</ComboBox>
<ComboBox x:Name="BgAlign" Header="Alignment" SelectedIndex="4" Width="230">
<ComboBoxItem Content="Top Left" /><ComboBoxItem Content="Top Center" /><ComboBoxItem Content="Top Right" /><ComboBoxItem Content="Center Left" /><ComboBoxItem Content="Center" /><ComboBoxItem Content="Center Right" /><ComboBoxItem Content="Bottom Left" /><ComboBoxItem Content="Bottom Center" /><ComboBoxItem Content="Bottom Right" />
</ComboBox>
<Button Content="Apply Background" Click="OnApplyBackground" HorizontalAlignment="Stretch" />
</StackPanel>
</Flyout>
</DropDownButton.Flyout>
</DropDownButton>
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="10,0">
<StackPanel Orientation="Horizontal" Spacing="6"><FontIcon Glyph="&#xE74E;" FontSize="13" VerticalAlignment="Center" /><TextBlock Text="Export" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" /></StackPanel>
<DropDownButton.Flyout>
<MenuFlyout>
<MenuFlyoutItem Text="Save as..." Click="OnSaveAs" />
<MenuFlyoutItem Text="Export to PDF" Click="OnExportPdf" />
<MenuFlyoutItem Text="Export all to PDF" Click="OnExportAllPdf" />
</MenuFlyout>
</DropDownButton.Flyout>
</DropDownButton>
<Rectangle Width="1" Height="22" Fill="{StaticResource StrokeBrush}" Margin="5,0" />
<Button Style="{StaticResource IconButtonStyle}" Click="OnPin" ToolTipService.ToolTip="Pin to screen (floating)" AutomationProperties.Name="Pin to screen (floating)">
<FontIcon Glyph="&#xE718;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnCopy" ToolTipService.ToolTip="Copy to clipboard (Ctrl+C)" AutomationProperties.Name="Copy to clipboard (Ctrl+C)">
<FontIcon Glyph="&#xE8C8;" FontSize="15" />
</Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnUploadShare" ToolTipService.ToolTip="Upload to active destination" AutomationProperties.Name="Upload to active destination">
<FontIcon Glyph="&#xE72D;" FontSize="15" />
</Button>
<DropDownButton VerticalAlignment="Center" Height="34" CornerRadius="7" Background="Transparent" BorderThickness="0" Padding="6,0" ToolTipService.ToolTip="Choose / manage upload destination" AutomationProperties.Name="Choose / manage upload destination">
<FontIcon Glyph="&#xE70D;" FontSize="11" />
<DropDownButton.Flyout>
<MenuFlyout x:Name="UploadFlyout" Opening="OnUploadFlyoutOpening" />
</DropDownButton.Flyout>
</DropDownButton>
<Button Style="{StaticResource IconButtonStyle}" Click="OnSave" ToolTipService.ToolTip="Save annotated image (Ctrl+S)" AutomationProperties.Name="Save annotated image (Ctrl+S)">
<FontIcon Glyph="&#xE74E;" FontSize="15" />
</Button>
</StackPanel>
</Border>
<StackPanel x:Name="EmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="14" MaxWidth="440">
<Border Width="84" Height="84" CornerRadius="20" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" HorizontalAlignment="Center">
<FontIcon Glyph="&#xE722;" FontSize="34" Foreground="{StaticResource SubtleTextBrush}" />
</Border>
<TextBlock Text="No capture selected" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" />
<TextBlock Text="Grab a fresh screenshot or pick one from the sidebar to start annotating." Foreground="{StaticResource SubtleTextBrush}" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" MaxWidth="360" />
<StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,4,0,0">
<Button Style="{StaticResource BigActionButtonStyle}" Tag="area" Click="OnCaptureOption"><TextBlock Text="Capture Area" /></Button>
<Button Style="{StaticResource BigActionButtonStyle}" Tag="window" Click="OnCaptureOption"><TextBlock Text="Window" /></Button>
<Button Style="{StaticResource BigActionButtonStyle}" Tag="full" Click="OnCaptureOption"><TextBlock Text="Fullscreen" /></Button>
</StackPanel>
<TextBlock x:Name="HotkeyHintText" Text="Tip: Ctrl+Shift+A captures from anywhere." FontSize="12" Foreground="{StaticResource SubtleTextBrush}" HorizontalAlignment="Center" />
</StackPanel>
<Border x:Name="CaptureToast" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,18" Background="{StaticResource ToolbarBgBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" CornerRadius="12" Padding="10,8" Visibility="Collapsed">
<StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
<Border Width="54" Height="34" CornerRadius="6" Background="#0A0A0C" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
<Image x:Name="ToastThumb" Stretch="UniformToFill" CanDrag="True" DragStarting="OnToastDragStarting" ToolTipService.ToolTip="Drag me to a folder or app" AutomationProperties.Name="Drag me to a folder or app" />
</Border>
<TextBlock x:Name="ToastText" Text="Captured" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" FontSize="12" />
<Button Style="{StaticResource IconButtonStyle}" Click="OnCopy" ToolTipService.ToolTip="Copy" AutomationProperties.Name="Copy"><FontIcon Glyph="&#xE8C8;" FontSize="14" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnSave" ToolTipService.ToolTip="Save" AutomationProperties.Name="Save"><FontIcon Glyph="&#xE74E;" FontSize="14" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnUploadShare" ToolTipService.ToolTip="Upload" AutomationProperties.Name="Upload"><FontIcon Glyph="&#xE72D;" FontSize="14" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnOpenFolder" ToolTipService.ToolTip="Folder" AutomationProperties.Name="Folder"><FontIcon Glyph="&#xE838;" FontSize="14" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnPin" ToolTipService.ToolTip="Pin to screen" AutomationProperties.Name="Pin to screen"><FontIcon Glyph="&#xE718;" FontSize="14" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Click="OnToastDismiss" ToolTipService.ToolTip="Dismiss" AutomationProperties.Name="Dismiss"><FontIcon Glyph="&#xE711;" FontSize="14" /></Button>
</StackPanel>
</Border>
</Grid>
</Grid>
<Border Grid.Row="2" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,1,0,0" Padding="14,6">
<Grid ColumnDefinitions="*,Auto">
<TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" />
<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
<Button Style="{StaticResource IconButtonStyle}" Width="28" Height="26" Click="OnZoomOut" ToolTipService.ToolTip="Zoom out" AutomationProperties.Name="Zoom out"><FontIcon Glyph="&#xE738;" FontSize="13" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Width="40" Height="26" Click="OnZoomFit" ToolTipService.ToolTip="Fit to window" AutomationProperties.Name="Fit to window"><TextBlock Text="Fit" FontSize="12" /></Button>
<Button Style="{StaticResource IconButtonStyle}" Width="28" Height="26" Click="OnZoomIn" ToolTipService.ToolTip="Zoom in" AutomationProperties.Name="Zoom in"><FontIcon Glyph="&#xE710;" FontSize="13" /></Button>
<TextBlock x:Name="DimsText" Text="" Foreground="{StaticResource SubtleTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0" />
</StackPanel>
</Grid>
</Border>
</Grid>
</Window>
